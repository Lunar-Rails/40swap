{
    "name": "@40swap/server-backend",
    "private": true,
    "type": "module",
    "scripts": {
        "clean": "rm -rf dist",
        "build": "nest build",
        "cli": "node --loader ts-node/esm src/cli.ts",
        "start": "node dist/main.js",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main.js",
        "test": "node --experimental-vm-modules ../node_modules/jest/bin/jest.js --runInBand",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json"
    },
    "dependencies": {
        "@40swap/shared": "file:../shared",
        "@40swap/crypto-clients": "file:../crypto-clients",
        "@anatine/zod-nestjs": "^2.0.3",
        "@nestjs/common": "^10.3.10",
        "@nestjs/config": "^3.2.3",
        "@nestjs/core": "^10.3.10",
        "@nestjs/event-emitter": "^2.0.4",
        "@nestjs/platform-express": "^10.3.10",
        "@nestjs/swagger": "^8.1.1",
        "@nestjs/terminus": "^10.2.3",
        "@nestjs/typeorm": "^10.0.2",
        "@scure/bip32": "^1.6.2",
        "@vulpemventures/secp256k1-zkp": "^3.2.1",
        "bip32": "^5.0.0-rc.0",
        "bitcoinjs-lib": "6.1.6",
        "bolt11": "^1.4.1",
        "commander": "^14.0.0",
        "decimal.js": "^10.4.3",
        "ecpair": "2.1.0",
        "js-yaml": "^4.1.1",
        "liquidjs-lib": "^6.0.2-liquid.37",
        "moment": "^2.30.1",
        "node-fetch": "^3.3.2",
        "pg": "^8.12.0",
        "prom-client": "^15.1.3",
        "slip77": "^0.2.0",
        "tiny-secp256k1": "^2.2.3",
        "ts-node": "^10.9.2",
        "typeorm": "^0.3.20",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.4.2",
        "@nestjs/schematics": "^10.1.3",
        "@types/commander": "^2.12.5",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.14",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^22.1.0",
        "jest": "^29.7.0",
        "testcontainers": "^10.16.0",
        "ts-jest": "^29.3.1"
    }
}
